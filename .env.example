# Puerto que se publicará en el host (mapeo host -> contenedor)
EXPOSED_PORT=1234

# Puerto interno del servidor Camoufox dentro del contenedor
PORT=1234
WS_PATH=/

# Resolución del display virtual (Xvfb)
SCREEN_WIDTH=1280
SCREEN_HEIGHT=720
SCREEN_DEPTH=16

# Camoufox
GEOIP=true
HUMANIZE=true

# Proxy upstream opcional (déjalos vacíos si no usas proxy).
# Si solo PROXY_SERVER está definido, se usará sin auth.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Recursos del contenedor
MEM_LIMIT=2G
MEM_RESERVATION=1G
