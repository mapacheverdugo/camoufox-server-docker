# Port the service is exposed on (host -> container mapping).
# Camoufox always listens on 1234 inside the container.
PORT=1234
WS_PATH=/

# Virtual display (Xvfb). Set to false to skip Xvfb and run Camoufox headless.
ENABLE_XVFB=true
SCREEN_WIDTH=1280
SCREEN_HEIGHT=720
SCREEN_DEPTH=16

# Camoufox
GEOIP=true
HUMANIZE=true

# Optional upstream proxy (leave empty to disable).
# If only PROXY_SERVER is set, the proxy is used without authentication.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Container resources
MEM_LIMIT=2G
MEM_RESERVATION=1G

# Build args (only used by `docker compose build`).
# Empty = install the latest version available on PyPI.
PLAYWRIGHT_VERSION=
CAMOUFOX_VERSION=
